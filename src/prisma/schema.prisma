generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum QuestionType {
  CHOICE
  CASE_ANALYSIS
}

enum CaseAnswerType {
  FILL_BLANK
  SHORT_ANSWER
  DIAGRAM_FILL
}

enum ExamType {
  MOCK
  REAL
}

enum ExamSessionType {
  AM
  PM
  FULL
}

enum ExamAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum StudyPlanStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ExamSession {
  AM
  PM
}

enum AIImageGenerationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AIExplanationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  password            String
  name                String
  targetExamDate      DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  answers             UserAnswer[]
  wrongNotes          WrongNote[]
  practiceSessions    PracticeSession[]
  caseAnswers         UserCaseAnswer[]
  examAttempts        ExamAttempt[]
  studyPlans          StudyPlan[]
  aiGenerations            AIQuestionGeneration[]
  aiImageGenerations       AIImageGeneration[]
  aiExplanationGenerations AIExplanationGeneration[]
  aiChatSessions           AIChatSession[]
  aiSettings          UserAISettings?
  passwordResetTokens PasswordResetToken[]

  @@index([createdAt])
}

model UserAISettings {
  userId                  String    @id
  provider                String?
  model                   String?
  apiKey                  String?
  apiKeyEncrypted         String?
  baseUrl                 String?
  visionSupport           Boolean?
  imageProvider           String?
  imageModel              String?
  imageApiKey             String?
  imageApiKeyEncrypted    String?
  imageBaseUrl            String?
  imageSize               String?
  imageQuality            String?
  imageOutputFormat       String?
  imageStyle              String?
  imageRateLimitPerMinute Int?
  imageRateLimitHourly    Int?
  imageRateLimitDaily     Int?
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model KnowledgePoint {
  id          String           @id @default(cuid())
  name        String
  parentId    String?
  sortOrder   Int              @default(0)
  description String?
  parent      KnowledgePoint?  @relation("KnowledgePointTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    KnowledgePoint[] @relation("KnowledgePointTree")
  questions   Question[]

  @@index([parentId])
  @@index([sortOrder])
}

model Question {
  id                 String                    @id @default(cuid())
  content            String
  type               QuestionType              @default(CHOICE)
  difficulty         Int
  year               Int
  session            ExamSession
  questionNumber     Int
  explanation        String
  isAIGenerated      Boolean                   @default(false)
  aiGeneratedBy      String?
  createdByUserId    String?
  knowledgePointId   String
  knowledgePoint     KnowledgePoint            @relation(fields: [knowledgePointId], references: [id], onDelete: Restrict)
  options            QuestionOption[]
  userAnswers        UserAnswer[]
  wrongNotes         WrongNote[]
  aiImageGenerations       AIImageGeneration[]
  aiExplanationGenerations AIExplanationGeneration[]
  practiceSessions         PracticeSessionQuestion[]
  caseScenario       CaseScenario?
  examQuestions      ExamQuestion[]
  examAnswers        ExamAnswer[]

  @@unique([year, session, questionNumber])
  @@index([isAIGenerated])
  @@index([knowledgePointId])
  @@index([difficulty])
  @@index([year, session])
  @@index([createdByUserId])
}

model AIQuestionGeneration {
  id                  String   @id @default(cuid())
  userId              String
  type                String
  knowledgePointNames String
  difficulty          Int
  count               Int
  caseType            String?
  questionIds         Json
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
}

model AIChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model QuestionOption {
  id          String       @id @default(cuid())
  questionId  String
  label       String
  content     String
  isCorrect   Boolean      @default(false)
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers     UserAnswer[]
  examAnswers ExamAnswer[]

  @@unique([questionId, label])
  @@index([questionId])
  @@index([isCorrect])
}

model UserAnswer {
  id                String           @id @default(cuid())
  userId            String
  questionId        String
  selectedOptionId  String
  practiceSessionId String?
  isCorrect         Boolean
  timeSpent         Int
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  question          Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption    QuestionOption   @relation(fields: [selectedOptionId], references: [id], onDelete: Restrict)
  practiceSession   PracticeSession? @relation(fields: [practiceSessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([practiceSessionId])
  @@index([questionId])
  @@index([isCorrect])
}

model PracticeSession {
  id          String                    @id @default(cuid())
  userId      String
  mode        String
  topicId     String?
  total       Int
  startedAt   DateTime                  @default(now())
  completedAt DateTime?
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   PracticeSessionQuestion[]
  answers     UserAnswer[]

  @@index([userId, startedAt])
  @@index([mode])
}

model PracticeSessionQuestion {
  id                String          @id @default(cuid())
  practiceSessionId String
  questionId        String
  order             Int
  practiceSession   PracticeSession @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  question          Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([practiceSessionId, questionId])
  @@index([practiceSessionId, order])
  @@index([questionId])
}

model WrongNote {
  id                 String              @id @default(cuid())
  userId             String
  questionId         String
  note               String?
  markedMastered     Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  question           Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  aiImageGenerations       AIImageGeneration[]
  aiExplanationGenerations AIExplanationGeneration[]

  @@unique([userId, questionId])
  @@index([userId, markedMastered])
  @@index([userId, markedMastered, updatedAt])
  @@index([userId, updatedAt])
  @@index([questionId])
  @@index([createdAt])
}

model AIImageGeneration {
  id                String                  @id @default(cuid())
  userId            String
  questionId        String
  wrongNoteId       String?
  wrongOptionId     String?
  status            AIImageGenerationStatus @default(PENDING)
  provider          String
  model             String
  promptProvider    String
  promptModel       String
  imageSize         String
  imageQuality      String
  imageOutputFormat String
  imageStyle        String
  fingerprint       String
  promptPayload     Json?
  imagePrompt       String?
  imagePath         String?
  sourceImagePath   String?
  errorMessage      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  completedAt       DateTime?
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  question          Question                @relation(fields: [questionId], references: [id], onDelete: Cascade)
  wrongNote         WrongNote?              @relation(fields: [wrongNoteId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, status, updatedAt])
  @@index([userId, wrongNoteId, updatedAt])
  @@index([questionId])
  @@index([wrongNoteId, status, createdAt])
  @@index([fingerprint])
}

model AIExplanationGeneration {
  id            String              @id @default(cuid())
  userId        String
  questionId    String
  wrongNoteId   String?
  wrongOptionId String?
  status        AIExplanationStatus @default(PENDING)
  provider      String
  model         String
  content       String?
  errorMessage  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  completedAt   DateTime?
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  question      Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  wrongNote     WrongNote?          @relation(fields: [wrongNoteId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, wrongNoteId, updatedAt])
  @@index([questionId])
  @@index([wrongNoteId, status, createdAt])
}

model CaseScenario {
  id           String            @id @default(cuid())
  questionId   String            @unique
  background   String
  figures      Json?
  question     Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  subQuestions CaseSubQuestion[]

  @@index([questionId])
}

model CaseSubQuestion {
  id              String           @id @default(cuid())
  caseScenarioId  String
  subNumber       Int
  content         String
  answerType      CaseAnswerType
  referenceAnswer String
  score           Int
  explanation     String
  caseScenario    CaseScenario     @relation(fields: [caseScenarioId], references: [id], onDelete: Cascade)
  userAnswers     UserCaseAnswer[]

  @@unique([caseScenarioId, subNumber])
  @@index([caseScenarioId])
}

model UserCaseAnswer {
  id                String          @id @default(cuid())
  userId            String
  caseSubQuestionId String
  answer            String
  score             Int?
  feedback          String?
  createdAt         DateTime        @default(now())
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseSubQuestion   CaseSubQuestion @relation(fields: [caseSubQuestionId], references: [id], onDelete: Cascade)

  @@unique([userId, caseSubQuestionId])
  @@index([userId, createdAt])
  @@index([caseSubQuestionId])
}

model Exam {
  id              String          @id @default(cuid())
  title           String
  type            ExamType        @default(MOCK)
  session         ExamSessionType
  timeLimit       Int
  totalScore      Int
  createdByUserId String?
  createdAt       DateTime        @default(now())
  questions       ExamQuestion[]
  attempts        ExamAttempt[]

  @@index([session])
  @@index([createdAt])
  @@index([createdByUserId])
}

model ExamQuestion {
  id          String   @id @default(cuid())
  examId      String
  questionId  String
  orderNumber Int
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
  @@unique([examId, orderNumber])
  @@index([questionId])
}

model ExamAttempt {
  id          String            @id @default(cuid())
  userId      String
  examId      String
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?
  status      ExamAttemptStatus @default(IN_PROGRESS)
  totalScore  Int?
  choiceScore Int?
  caseScore   Int?
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers     ExamAnswer[]

  @@index([userId, startedAt])
  @@index([examId])
  @@index([status])
}

model ExamAnswer {
  id               String          @id @default(cuid())
  examAttemptId    String
  questionId       String
  selectedOptionId String?
  caseAnswers      Json?
  isCorrect        Boolean?
  score            Int?
  timeSpent        Int             @default(0)
  examAttempt      ExamAttempt     @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  question         Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([examAttemptId, questionId])
  @@index([questionId])
  @@index([selectedOptionId])
}

model StudyPlan {
  id             String          @id @default(cuid())
  userId         String
  title          String
  content        String
  targetExamDate DateTime
  totalDays      Int
  status         StudyPlanStatus @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  days           StudyPlanDay[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([targetExamDate])
}

model StudyPlanDay {
  id          String    @id @default(cuid())
  studyPlanId String
  dayNumber   Int
  date        DateTime
  tasks       Json
  completed   Boolean   @default(false)
  notes       String?
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@unique([studyPlanId, dayNumber])
  @@index([date])
}
