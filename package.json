{
  "name": "ose",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source AI-powered exam preparation platform for China's Software Professional Qualification Exam",
  "author": "OSE Contributors",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/hacksynth/ose",
  "repository": {
    "type": "git",
    "url": "https://github.com/hacksynth/ose.git"
  },
  "bugs": {
    "url": "https://github.com/hacksynth/ose/issues"
  },
  "keywords": [
    "software-exam",
    "ruankao",
    "exam-preparation",
    "ai-powered",
    "education",
    "nextjs",
    "open-source",
    "self-hosted"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema src/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema src/prisma/schema.prisma",
    "db:studio": "prisma studio --schema src/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema src/prisma/schema.prisma",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android:init": "tauri android init --ci",
    "tauri:android:build:apk": "node scripts/build-android-apk.js",
    "tauri:prepare": "node scripts/prepare-sidecar.js",
    "tauri:icons": "tauri icon src-tauri/icons/app-icon.png",
    "verify:portable": "node scripts/verify-portable.js",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "prepare": "husky && npx prisma generate --schema src/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "tsx src/prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@google/genai": "^1.50.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.35.0",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "next-test-api-route-handler": "^5.0.4",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.3",
    "vitest": "^4.1.5"
  }
}
